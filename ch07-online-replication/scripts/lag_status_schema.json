{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/lsr/1.0.0",
  "title": "Lag Status Report",
  "description": "Output of lag_monitor.py. Captures the operational state of every Extract and Replicat process in a GoldenGate Microservices deployment, plus a max_lag_seconds aggregate the cutover-drain orchestrator gates on.",
  "type": "object",
  "required": [
    "_artifact",
    "captured_at_utc", "lsr_version", "gg_server",
    "extract_count", "replicat_count",
    "max_lag_seconds", "extracts", "replicats", "all_running"
  ],
  "properties": {
    "_artifact":       { "const": "lsr" },
    "captured_at_utc": { "type": "string", "format": "date-time" },
    "lsr_version":     { "type": "string" },
    "gg_server":       { "type": "string", "format": "uri" },
    "extract_count":   { "type": "integer", "minimum": 0 },
    "replicat_count":  { "type": "integer", "minimum": 0 },
    "max_lag_seconds": { "type": "number",  "minimum": 0 },
    "all_running":     { "type": "boolean" },
    "extracts":        { "$ref": "#/$defs/processArray" },
    "replicats":       { "$ref": "#/$defs/processArray" }
  },
  "$defs": {
    "processArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "name", "status", "lag_seconds"],
        "properties": {
          "kind":        { "enum": ["extract", "replicat"] },
          "name":        { "type": ["string", "null"] },
          "status":      { "type": ["string", "null"] },
          "lag_seconds": { "type": "number", "minimum": 0 },
          "checkpoint":  { "type": ["string", "object", "null"] },
          "messages":    {
            "type": "array",
            "items": { "type": ["string", "object"] }
          }
        }
      }
    }
  }
}
