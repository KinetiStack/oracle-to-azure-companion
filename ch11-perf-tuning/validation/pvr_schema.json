{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/pvr/1.0.0",
  "title": "Performance Validation Report",
  "description": "Output of pvr_runner.py. Per-query outcome comparison source vs target with PASS/DEGRADED/REGRESSED/FAIL classification. The signed artifact compliance and engineering management consume to verify the migrated target's perf posture against the source's baseline.",
  "type": "object",
  "required": [
    "_artifact",
    "pvr_version", "generated_at_utc",
    "source_engine", "target_engine",
    "regression_threshold", "summary", "queries", "open_questions"
  ],
  "properties": {
    "_artifact":            { "const": "pvr" },
    "pvr_version":          { "type": "string" },
    "generated_at_utc":     { "type": "string", "format": "date-time" },
    "source_engine":        { "enum": ["oracle", "mssql", "pg"] },
    "target_engine":        { "enum": ["oracle", "mssql", "pg"] },
    "regression_threshold": { "type": "number", "exclusiveMinimum": 1 },
    "summary": {
      "type": "object",
      "required": ["total_queries", "by_status"],
      "properties": {
        "total_queries": { "type": "integer", "minimum": 0 },
        "by_status": {
          "type": "object",
          "required": ["PASS", "DEGRADED", "REGRESSED", "FAIL"],
          "properties": {
            "PASS":      { "type": "integer", "minimum": 0 },
            "DEGRADED":  { "type": "integer", "minimum": 0 },
            "REGRESSED": { "type": "integer", "minimum": 0 },
            "FAIL":      { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query_id", "description",
                     "source_metrics", "target_metrics",
                     "status", "notes"],
        "properties": {
          "query_id":          { "type": "string" },
          "description":       { "type": "string" },
          "source_metrics":    { "$ref": "#/$defs/queryMetrics" },
          "target_metrics":    { "$ref": "#/$defs/queryMetrics" },
          "regression_factor": { "type": ["number", "null"], "minimum": 0 },
          "status":            { "enum": ["PASS", "DEGRADED", "REGRESSED", "FAIL"] },
          "notes":             { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "queryMetrics": {
      "type": "object",
      "required": ["latency_seconds_min", "latency_seconds_median",
                   "latency_seconds_max", "rows_returned", "runs"],
      "properties": {
        "latency_seconds_min":    { "type": ["number", "null"], "minimum": 0 },
        "latency_seconds_median": { "type": ["number", "null"], "minimum": 0 },
        "latency_seconds_max":    { "type": ["number", "null"], "minimum": 0 },
        "rows_returned":          { "type": "integer", "minimum": 0 },
        "error":                  { "type": ["string", "null"] },
        "runs":                   { "type": "integer", "minimum": 0 },
        "warmup_runs_skipped":    { "type": "integer", "minimum": 0 }
      }
    }
  }
}
