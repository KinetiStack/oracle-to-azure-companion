{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request;Exception"
      }
    },
    "logLevel": {
      "default":                     "Information",
      "Function.files_to_emit_consumer":            "Information",
      "Host.Aggregator":             "Trace"
    }
  },
  "functionTimeout": "00:05:00",
  "extensionBundle": {
    "id":      "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
