{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/tco_bom/1.0.0",
  "title": "TCO Bill of Materials",
  "description": "Output document produced by tco_sizer.py. Consumed by the migration program's finance and architecture review. License dollar costs are intentionally excluded (BYOL is customer-specific).",
  "type": "object",
  "required": [
    "_artifact",
    "tasm_run_id",
    "generated_at_utc",
    "sizer_version",
    "target",
    "options",
    "pricing_caveats",
    "compute",
    "storage",
    "oracle_licensing",
    "network",
    "cost_estimate_usd",
    "open_questions"
  ],
  "properties": {
    "_artifact":        { "const": "bom" },
    "tasm_run_id":      { "type": ["string", "null"] },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "sizer_version":    { "type": "string" },
    "target": {
      "type": "string",
      "enum": [
        "Oracle Database@Azure",
        "Oracle on Azure IaaS (single-instance)",
        "Oracle on Azure IaaS RAC (FlashGrid)",
        "Azure SQL Managed Instance",
        "Azure Database for PostgreSQL Flexible Server"
      ]
    },
    "options": {
      "type": "object",
      "required": ["term_years", "reserved", "workload_class",
                   "prefer_constrained_vcpu", "hyperthreading_enabled", "oracle_edition"],
      "properties": {
        "term_years":              { "type": "integer", "minimum": 1, "maximum": 10 },
        "reserved":                { "type": "boolean" },
        "workload_class":          { "type": "string", "enum": ["oltp", "olap"] },
        "prefer_constrained_vcpu": { "type": "boolean" },
        "hyperthreading_enabled":  { "type": "boolean" },
        "oracle_edition":          { "type": "string", "enum": ["EE", "SE2"] }
      }
    },
    "pricing_caveats": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "compute": {
      "type": "object",
      "required": ["sku", "parent_sku", "instances", "rationale"],
      "properties": {
        "sku":          { "type": "string" },
        "parent_sku":   { "type": "string" },
        "instances":    { "type": "integer", "minimum": 1 },
        "vcpu_total":   { "type": ["integer", "null"], "minimum": 0 },
        "vcpu_active":  { "type": ["integer", "null"], "minimum": 0 },
        "memory_gib":   { "type": ["integer", "null"], "minimum": 0 },
        "series_note":  { "type": "string" },
        "rationale":    { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "required": ["tier", "rationale"],
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "Exadata Smart Storage (Oracle Database@Azure native)",
            "Azure Premium SSD v2",
            "Azure Ultra Disk",
            "Azure NetApp Files (Ultra service level)"
          ]
        },
        "capacity_gib":     { "type": ["integer", "null"], "minimum": 0 },
        "provisioned_iops": { "type": ["integer", "null"], "minimum": 0 },
        "provisioned_mbps": { "type": ["integer", "null"], "minimum": 0 },
        "rationale":        { "type": "string" }
      }
    },
    "oracle_licensing": {
      "type": "object",
      "required": ["applicable", "rationale"],
      "properties": {
        "applicable":                   { "type": "boolean" },
        "edition":                      { "type": ["string", "null"], "enum": ["EE", "SE2", null] },
        "vcpus_chargeable":             { "type": ["integer", "null"], "minimum": 0 },
        "hyperthreading_assumed":       { "type": ["boolean", "null"] },
        "processor_licenses_required":  { "type": ["integer", "null"], "minimum": 0 },
        "rationale":                    { "type": "string" }
      }
    },
    "network": {
      "type": "object",
      "required": ["egress_gb_per_month_estimate", "egress_rate_usd_per_gb",
                   "expressroute_recommended"],
      "properties": {
        "egress_gb_per_month_estimate": { "type": "number", "minimum": 0 },
        "egress_rate_usd_per_gb":       { "type": "number", "minimum": 0 },
        "expressroute_recommended":     { "type": "boolean" }
      }
    },
    "cost_estimate_usd": {
      "type": "object",
      "required": ["compute_payg_monthly", "compute_ri_3yr_monthly",
                   "storage_monthly", "network_monthly",
                   "total_monthly_payg", "total_monthly_ri_3yr",
                   "total_term_payg",   "total_term_ri_3yr",
                   "term_years", "oracle_license_cost_excluded"],
      "properties": {
        "compute_payg_monthly":         { "type": "number", "minimum": 0 },
        "compute_ri_3yr_monthly":       { "type": "number", "minimum": 0 },
        "storage_monthly":              { "type": "number", "minimum": 0 },
        "network_monthly":              { "type": "number", "minimum": 0 },
        "total_monthly_payg":           { "type": "number", "minimum": 0 },
        "total_monthly_ri_3yr":         { "type": "number", "minimum": 0 },
        "total_term_payg":              { "type": "number", "minimum": 0 },
        "total_term_ri_3yr":            { "type": "number", "minimum": 0 },
        "term_years":                   { "type": "integer", "minimum": 1 },
        "oracle_license_cost_excluded": { "type": "boolean", "const": true }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
