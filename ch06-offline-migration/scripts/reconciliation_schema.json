{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/mrr/1.0.0",
  "title": "Migration Reconciliation Report",
  "description": "Output of reconcile.py. Proves source = target after an offline data migration via row-count + sample-row hash comparison. Consumed by the cutover playbook (Ch.12).",
  "type": "object",
  "required": [
    "_artifact",
    "schema", "source_db", "target_engine",
    "generated_at_utc", "reconcile_version",
    "sample_size", "summary", "tables", "open_questions"
  ],
  "properties": {
    "_artifact":         { "const": "mrr" },
    "schema":            { "type": "string" },
    "target_schema":     { "type": "string" },
    "source_db":         { "type": "string" },
    "target_engine":     { "enum": ["oracle", "mssql", "pg"] },
    "target_endpoint":   { "type": "string" },
    "generated_at_utc":  { "type": "string", "format": "date-time" },
    "reconcile_version": { "type": "string" },
    "sample_size":       { "type": "integer", "minimum": 0 },
    "summary": {
      "type": "object",
      "required": ["total_tables", "tables_pass", "tables_with_delta",
                   "tables_missing", "tables_error",
                   "total_source_rows", "total_target_rows"],
      "properties": {
        "total_tables":      { "type": "integer", "minimum": 0 },
        "tables_pass":       { "type": "integer", "minimum": 0 },
        "tables_with_delta": { "type": "integer", "minimum": 0 },
        "tables_missing":    { "type": "integer", "minimum": 0 },
        "tables_error":      { "type": "integer", "minimum": 0 },
        "total_source_rows": { "type": "integer", "minimum": 0 },
        "total_target_rows": { "type": "integer", "minimum": 0 }
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "table_name", "status",
                     "source_row_count", "target_row_count",
                     "sample_size", "hash_matches", "hash_mismatches"],
        "properties": {
          "owner":            { "type": "string" },
          "table_name":       { "type": "string" },
          "status":           { "enum": ["PASS", "DELTA", "MISSING", "ERROR"] },
          "source_row_count": { "type": ["integer", "null"], "minimum": 0 },
          "target_row_count": { "type": ["integer", "null"], "minimum": 0 },
          "row_delta":        { "type": ["integer", "null"] },
          "row_delta_pct":    { "type": ["number",  "null"] },
          "sample_size":      { "type": "integer", "minimum": 0 },
          "hash_matches":     { "type": "integer", "minimum": 0 },
          "hash_mismatches":  { "type": "integer", "minimum": 0 },
          "error_message":    { "type": ["string", "null"] }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
