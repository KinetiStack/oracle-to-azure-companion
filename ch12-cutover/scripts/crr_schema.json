{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/crr/1.0.0",
  "title": "Cutover Readiness Report",
  "description": "Output of crr_aggregator.py. Aggregates every signed JSON deliverable from Ch.1-11 into one go/no-go verdict. Consumed by the cutover playbook AS the cutover-readiness gate -- exit code 0 = GO, 1 = HOLD, 2 = NO_GO.",
  "type": "object",
  "required": [
    "_artifact",
    "crr_version", "generated_at_utc", "verdict",
    "blocking_gates", "degraded_gates", "gates", "open_questions"
  ],
  "properties": {
    "_artifact":        { "const": "crr" },
    "crr_version":      { "type": "string" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "verdict":          { "enum": ["GO", "HOLD", "NO_GO"] },
    "blocking_gates":   { "type": "array", "items": { "type": "string" } },
    "degraded_gates":   { "type": "array", "items": { "type": "string" } },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "present", "status", "summary", "open_question_count"],
        "properties": {
          "name":                { "type": "string" },
          "present":             { "type": "boolean" },
          "status":              { "enum": ["PASS", "DEGRADED", "FAIL", "MISSING"] },
          "summary":             { "type": "object" },
          "open_question_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } }
  }
}
