{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "escalation_matrix.schema.json",
  "title": "Cutover Escalation Matrix",
  "description": "Schema for runbook/escalation_matrix.json. Rejects 'TBD'/placeholder values and template-default fields so a half-filled matrix cannot be approved as cutover-ready. The template ships in a failing state on purpose: validate_escalation_matrix.py against the template emits NO_GO until every field is real.",
  "type": "object",
  "required": [
    "version",
    "last_updated",
    "cutover_window",
    "war_room",
    "roles",
    "escalation_paths"
  ],
  "additionalProperties": true,
  "$defs": {
    "non_placeholder_string": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "(?i)\\bTBD\\b" },
          { "pattern": "(?i)\\bTODO\\b" },
          { "pattern": "^\\?+$" },
          { "pattern": "^X{2,}$" },
          { "pattern": "^REPLACE_BEFORE_USE$" }
        ]
      }
    },
    "slack_handle": {
      "description": "Slack/Teams handle. Must start with '@' and have at least 2 chars after.",
      "type": "string",
      "pattern": "^@[A-Za-z0-9._-]{2,}$"
    },
    "phone_number": {
      "description": "Phone in E.164-ish form. Permits +, digits, spaces, dashes, dots, parentheses; minimum 7 dialable chars.",
      "type": "string",
      "pattern": "^[+0-9][0-9 .()\\-/]{6,}$"
    },
    "iso_date": {
      "description": "ISO-8601 date YYYY-MM-DD. Template ships with 'REPLACE_BEFORE_USE' which fails this pattern, so the matrix cannot validate until last_updated is set.",
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$"
    },
    "contact": {
      "type": "object",
      "required": ["name", "slack", "phone"],
      "additionalProperties": false,
      "properties": {
        "name":  { "$ref": "#/$defs/non_placeholder_string" },
        "slack": { "$ref": "#/$defs/slack_handle" },
        "phone": { "$ref": "#/$defs/phone_number" }
      }
    },
    "role": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": { "$ref": "#/$defs/contact" },
        "backup":  { "$ref": "#/$defs/contact" }
      }
    },
    "role_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    }
  },
  "properties": {
    "_comment":     { "type": "string" },
    "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_updated": { "$ref": "#/$defs/iso_date" },
    "cutover_window": { "$ref": "#/$defs/non_placeholder_string" },
    "war_room": {
      "type": "object",
      "required": ["bridge_url", "chat_channel"],
      "additionalProperties": false,
      "properties": {
        "bridge_url":    { "$ref": "#/$defs/non_placeholder_string" },
        "backup_bridge": { "$ref": "#/$defs/non_placeholder_string" },
        "chat_channel":  { "type": "string", "pattern": "^#[A-Za-z0-9_-]+$" }
      }
    },
    "roles": {
      "type": "object",
      "required": ["cutover_lead", "dba_oncall", "application_oncall"],
      "propertyNames": { "$ref": "#/$defs/role_key" },
      "additionalProperties": { "$ref": "#/$defs/role" }
    },
    "escalation_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trigger", "first", "decision"],
        "additionalProperties": false,
        "properties": {
          "trigger":  { "type": "string", "minLength": 5 },
          "first":    { "$ref": "#/$defs/role_key" },
          "second":   { "$ref": "#/$defs/role_key" },
          "third":    { "$ref": "#/$defs/role_key" },
          "decision": { "type": "string", "minLength": 5 }
        }
      }
    }
  }
}
