{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinetistack.io/schemas/car/1.0.0",
  "title": "Conversion Assessment Report",
  "description": "Output document from conversion_diff.py. Quantifies the per-object conversion result for each pipeline (SSMA for Oracle, Ora2Pg) so the migration program has a single signed artifact for the schema-conversion decision.",
  "type": "object",
  "required": [
    "_artifact",
    "schema", "generated_at_utc", "car_version",
    "total_objects", "summary", "objects", "open_questions"
  ],
  "properties": {
    "_artifact":        { "const": "car" },
    "schema":           { "type": "string" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "car_version":      { "type": "string" },
    "total_objects":    { "type": "integer", "minimum": 0 },
    "summary": {
      "type": "object",
      "required": ["ssma_converted", "ssma_pct",
                   "ora2pg_converted", "ora2pg_pct",
                   "both_converted", "neither_converted"],
      "properties": {
        "ssma_converted":   { "type": "integer", "minimum": 0 },
        "ssma_pct":         { "type": "number",  "minimum": 0, "maximum": 100 },
        "ora2pg_converted": { "type": "integer", "minimum": 0 },
        "ora2pg_pct":       { "type": "number",  "minimum": 0, "maximum": 100 },
        "both_converted":   { "type": "integer", "minimum": 0 },
        "neither_converted":{ "type": "integer", "minimum": 0 }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "object_name", "object_type", "ssma", "ora2pg"],
        "properties": {
          "owner":       { "type": "string" },
          "object_name": { "type": "string" },
          "object_type": { "type": "string" },
          "ssma":        { "$ref": "#/$defs/converterResult" },
          "ora2pg":      { "$ref": "#/$defs/converterResult" }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "converterResult": {
      "type": "object",
      "required": ["converted", "warnings"],
      "properties": {
        "converted": { "type": "boolean" },
        "warnings":  { "type": "integer", "minimum": 0 },
        "file":      { "type": ["string", "null"] }
      }
    }
  }
}
